# syntax=docker/dockerfile:1
# =============================================================================
# radix/godot-server:latest — Base runner for Godot game server containers
#
# Build:
#   docker build -t radix/godot-server:latest -f runner/Dockerfile.godot runner/
#
# The entrypoint downloads the actual game build at runtime via RADIX_BUILD_URL,
# extracts it, and launches the binary specified by RADIX_EXECUTABLE.
# =============================================================================
FROM ubuntu:22.04

LABEL maintainer="Radix BaaS <dev@radix.baas>"
LABEL description="Base runner image for Radix-managed Godot game servers"

# Prevent apt from prompting during install
ENV DEBIAN_FRONTEND=noninteractive

# ------------------------------------------------------------------
# Install runtime dependencies
# ------------------------------------------------------------------
RUN apt-get update -qq \
 && apt-get install -y -qq --no-install-recommends \
    ca-certificates \
    curl \
    wget \
    unzip \
    libc6 \
    libssl3 \
    libgcc-s1 \
    libstdc++6 \
    libx11-6 \
    libxcursor1 \
    libxrandr2 \
    libxinerama1 \
    libxi6 \
    libgl1-mesa-glx \
    libglu1-mesa \
    libasound2 \
    libpulse0 \
    libdbus-1-3 \
    libnss3 \
    libfreetype6 \
    libfontconfig1 \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------------
# Non-root runner user
# ------------------------------------------------------------------
RUN groupadd -r runner && useradd -r -g runner -m -d /home/runner runner

# ------------------------------------------------------------------
# Runner structure
# ------------------------------------------------------------------
RUN mkdir -p /game && chown runner:runner /game && chmod 755 /game
WORKDIR /game

# ------------------------------------------------------------------
# Expose common game server ports (UDP)
# ------------------------------------------------------------------
EXPOSE 7777/udp

# ------------------------------------------------------------------
# Entrypoint (installed as root)
# ------------------------------------------------------------------
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# ------------------------------------------------------------------
# Drop privileges for runtime
# ------------------------------------------------------------------
USER runner

ENTRYPOINT ["/entrypoint.sh"]
