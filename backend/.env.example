# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ─── Database ──────────────────────────────────────────
# Set DB_TYPE=postgres to use PostgreSQL (defaults to sqljs in dev)
DB_TYPE=sqljs
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_DATABASE=radix

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=generate-a-random-64-char-secret
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=generate-another-random-64-char-secret
JWT_REFRESH_EXPIRATION=7d

# ─── Encryption ────────────────────────────────────────
# 32 chars exactly for AES-256
ENCRYPTION_KEY=change-this-to-a-32-char-key!!!!!

# ─── Redis (optional, production) ──────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Rate Limiting ─────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── File Upload ───────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=524288000

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Discord (optional) ────────────────────────────────
DISCORD_WEBHOOK_URL=

# ─── Monitoring (optional) ─────────────────────────────
PROMETHEUS_ENABLED=false
